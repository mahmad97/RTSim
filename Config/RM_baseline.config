
; Non-PIM DWM main-memory baseline (processor + DWM, no in-memory compute).
;
; This is the conventional von-Neumann reference for the HIMA-DWM comparison: an
; edge host CPU (32 nm application core with SIMD, at the 500 MHz / 2 ns
; comparison cycle -- matched to HIMA-DWM's regime, not a server Xeon) performs
; every MAC, and the DWM is plain main memory -- it only reads, writes, and
; shifts operands; there is NO LIM (in-memory compute) op. The
; per-access energies are the NON-PIM single-domain SB-read cell (NVSim
; configs/dwm_sb.cfg, the paper Table IV "Baseline" row), distinct from the
; HIMA-DWM compute cell (dwm_sb_pim_7) used by RM_hima_dwm.config / RM_hima_dwm_array.config.
;
; Read 11.079 pJ, Write 11.606 pJ, Shift 14.124 pJ per 32-bit word access
; (NVSim, 4 MB effective bank, 32 nm HP). Leakage (125.09 mW) and area
; (0.80 mm^2) are reported by NVSim and accounted separately, matching the
; HIMA-DWM config which also excludes leakage from the dynamic figure.

MemType RTM

CLK 2000
RATE 2
BusWidth 32
DeviceWidth 32
CPUFreq 2000

BANKS 1
RANKS 1
CHANNELS 1
DBCS 1024
DOMAINS 64
WordSize 32
MATHeight 1024
nPorts 2
PortAccess static
PortUpdate lazy

UseRefresh false
RefreshRows 1
BanksPerRefresh 1
DelayedRefreshThreshold 1

MEM_CTL RTM
ClosePage 0
AddressMappingScheme RK:BK:CH:R:C
Decoder DRCDecoder
INTERCONNECT OffChipBus

; Timing (memory cycles) -- same flat model as RM_hima_dwm_array.config.
tSH 1
tRD 1
tWR 2
tACT 1

tRAS 0
tCMD 1
tBURST 4
tRCD 2
tWP 4
tRP 1
tCAS 1
tAL 0
tCCD 1
tCWD 1
tWTR 3
tRTRS 1
tRTP 1
tOST 0
tRRDR 4
tRRDW 4
RAW 4
tRAW 4
tRDPDEN 5
tWRPDEN 6
tWRAPDEN 6
tPD 1
tXP 3
tXPDLL 200000
tRFC 100
tREFW 42666667

EnergyModel energy

; Non-PIM dwm_sb per-access energies (nJ).
Erd 0.011079
Eopenrd 0
Ewr 0.011606
Esh 0.014124
Ewrpb 0
Eleak 0
Eopen 0
Eclosed 0
Epdpf 0
Epdps 0
Epda 0
Eref 0

Voltage 1.8
EIDD0 0
EIDD1 0
EIDD2P0 0
EIDD2P1 0
EIDD2N 0
EIDD2NT 0
EIDD3P 0
EIDD3N 0
EIDD4R 0
EIDD4W 0
EIDD5B 0
EIDD6 0

; No in-memory compute on the baseline DWM.
Elim 0
tLIM 1
Eset 0
Ereset 0

; Inter-bank transfer (nJ/byte) -- 1250 pJ/B (CORUSCANT). Inert for single-bank
; LeNet-5; present for multi-bank workloads (AlexNet).
Etrans 1.25
tTRANS 1
